# ===== Chave da API Anthropic (obrigatória para a transcrição) =====
# Crie em https://console.anthropic.com/ -> Settings -> API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Modelo de visão usado na transcrição (pode trocar por claude-opus-4-8 p/ mais precisão)
MODELO_TRANSCRICAO=claude-sonnet-4-6

# Porta da API/painel
PORT=3000

# Ligar (true) ou desligar (false) o WhatsApp.
# Use "false" para testar SÓ a transcrição (npm run transcrever) sem escanear QR.
HABILITAR_WHATSAPP=true
